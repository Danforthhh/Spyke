# No environment variables needed — API keys are stored as Cloudflare Worker secrets.
# Worker URLs are hardcoded in src/services/claudeClient.ts:
#   PROD: https://spyke.vin-bories.workers.dev
#   DEV:  https://dev-proxy.vin-bories.workers.dev
#
# To deploy the PROD worker:
#   cd worker/ && npx wrangler deploy
#   npx wrangler secret put ANTHROPIC_API_KEY
